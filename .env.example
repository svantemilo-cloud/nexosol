# Site URL (used in metadata and JSON-LD)
NEXT_PUBLIC_SITE_URL=https://nexosol.se

# Google Tag Manager container ID (e.g. GTM-XXXXXXX). Leave empty to disable GTM.
NEXT_PUBLIC_GTM_ID=

# Admin-panel lösenord (krävs för /admin). Default vid utelämnande: "nexosol"
ADMIN_PASSWORD=

# Valfritt: n8n-webhook för kalkylatorleads (POST JSON). Lämna tomt om du inte använder n8n.
NEXT_PUBLIC_N8N_WEBHOOK_URL=

# --- Nexoadmin / Supabase (webbleads → crm_user_workspace.submissions) ---
# När alla tre är satta skickas varje POST /api/submissions till Supabase innan lokalt minne.
# SUPABASE_URL kan uteslutas om NEXT_PUBLIC_SUPABASE_URL redan finns (samma projekt-URL).
# SUPABASE_SERVICE_ROLE_KEY får ALDRIG ha prefixet NEXT_PUBLIC_ (endast server).
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# UUID för auth.users-användaren som ska ta emot alla webbleads (samma som i Nexoadmin).
CRM_LEADS_TARGET_USER_ID=
# Alias som vissa deployment använder:
NEXOADMIN_CRM_USER_ID=
# Valfritt: källa i CRM-JSON (default: website).
CRM_LEAD_SOURCE=
# Valfritt: om satt måste begäran ha header x-crm-leads-secret eller Authorization: Bearer <samma värde>.
# Lämna tomt för vanlig publik kalkylator (annars måste klienten känna till hemligheten).
CRM_LEADS_INGRESS_SECRET=
